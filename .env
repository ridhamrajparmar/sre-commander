# ═══════════════════════════════════════════════════════════════════════════
#  AI SRE Commander — Environment Configuration
#  Copy this file to `.env` and adjust values as needed.
# ═══════════════════════════════════════════════════════════════════════════

# ── Cognee behaviour ───────────────────────────────────────────────────────
# Skip the 30-second LLM connection test — Ollama's first model load can
# exceed this timeout when swapping between models.
COGNEE_SKIP_CONNECTION_TEST=true
# Disable multi-tenant access control — Neo4j Community Edition doesn't
# support CREATE/DROP DATABASE required by cognee's multi-user mode.
ENABLE_BACKEND_ACCESS_CONTROL=false

# ── LLM Provider (Ollama — fully local) ────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama

# ── Embedding Provider (Ollama — fully local) ─────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5

# ── Vector Store (LanceDB — built-in, no external service needed) ──────────
VECTOR_DB_PROVIDER=lancedb

# ── Graph Store (Neo4j) ───────────────────────────────────────────────────
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=bolt://localhost:7687
GRAPH_DATABASE_NAME=neo4j
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=sre_commander_pass
